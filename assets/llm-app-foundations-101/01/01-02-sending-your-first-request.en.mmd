flowchart LR
    Env["os.environ['GROQ_API_KEY']"] --> Client["Groq(api_key=...)\nclient"]
    Prompt["user message\nExplain Python list comprehensions"] --> Call["client.chat.completions.create()"]
    Model["model='llama-3.1-8b-instant'"] --> Call
    Client --> Call
    Call --> Completion["completion object"]
    Completion --> Text["choices[0].message.content"]
    Completion --> Record["model + usage"]
    Text --> Print["print(answer)"]

    style Env fill:#fce4ec,stroke:#c2185b
    style Client fill:#f3e5f5,stroke:#7b1fa2
    style Prompt fill:#e3f2fd,stroke:#1976d2
    style Model fill:#e3f2fd,stroke:#1976d2
    style Call fill:#fff3e0,stroke:#f57c00
    style Completion fill:#ede7f6,stroke:#5e35b1
    style Text fill:#fff8e1,stroke:#f9a825
    style Record fill:#e0f7fa,stroke:#00838f
    style Print fill:#e8f5e9,stroke:#388e3c
