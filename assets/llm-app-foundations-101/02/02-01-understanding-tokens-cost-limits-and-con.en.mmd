flowchart LR
    RawText["Raw text\nquestion + history + docs"] --> Tokenizer["Tokenizer"]
    Tokenizer --> PromptTokens["prompt_tokens"]
    PromptTokens --> Budget["Shared context window"]
    PlannedOutput["planned answer"] --> CompletionTokens["completion_tokens"]
    CompletionTokens --> Budget
    Budget --> Cost["More total tokens\nmore cost"]
    Budget --> Latency["More tokens to read and generate\nmore latency"]
    Budget --> Limit["If budget is tight\ntruncation or overflow"]

    style RawText fill:#e3f2fd,stroke:#1976d2
    style Tokenizer fill:#f3e5f5,stroke:#7b1fa2
    style PromptTokens fill:#fff3e0,stroke:#f57c00
    style CompletionTokens fill:#fff3e0,stroke:#f57c00
    style Budget fill:#e8f5e9,stroke:#388e3c
    style Cost fill:#fff8e1,stroke:#f9a825
    style Latency fill:#ede7f6,stroke:#5e35b1
    style Limit fill:#ffebee,stroke:#c62828
