flowchart TB
    Start["Call the evaluation function"] --> EvalMode["model.eval()"]
    EvalMode --> Loop["Iterate over each eval row"]
    Loop --> Batch["row → torch.tensor batch"]
    Batch --> NoGrad["torch.no_grad()"]
    NoGrad --> Loss["model(**batch).loss"]

    Loss --> Collect["append loss.item()"]
    Collect --> Mean["compute mean loss"]
    Mean --> Exp["math.exp(mean_loss)"]
    Exp --> Perplexity["report perplexity"]

    Perplexity --> Compare["compare before and after training"]
    Perplexity --> Golden["read it beside a golden-set score"]
    Compare --> Regression["confirm the regression baseline"]
    Golden --> Regression
    Regression --> Conclusion["Check trend numbers and\nuser-facing quality together"]

    style Start fill:#e3f2fd,stroke:#1976d2
    style NoGrad fill:#e8f5e9,stroke:#388e3c
    style Perplexity fill:#f3e5f5,stroke:#7b1fa2
    style Conclusion fill:#fff8e1,stroke:#f9a825
