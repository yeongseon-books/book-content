flowchart LR
    Ask["Start by decomposing the request"] --> ChangeType["What must change?\nTone, format, or facts"]
    ChangeType --> Tone["Mostly tone and response format"]
    ChangeType --> Facts["Missing facts or domain knowledge"]

    Tone --> Boundary["Check the training-target boundary"]
    Boundary --> FreezeBase["Freeze the base weights"]
    Boundary --> TrainAdapter["Train only a small LoRA adapter"]
    TrainAdapter --> LowerCost["Fewer trainable parameters\nLess GPU memory"]
    LowerCost --> DeployChoice["Can deploy base model\nand adapter separately"]

    Facts --> KnowledgeSource["Where should new knowledge come from?"]
    KnowledgeSource --> NewData["New examples and domain data"]
    KnowledgeSource --> Retrieval["Document retrieval or RAG"]
    NewData --> FullUpdate["Do you need to rewrite most weights?"]
    FullUpdate -->|"yes"| FullFT["Full fine-tuning\nUpdate all weights"]
    FullUpdate -->|"no"| KeepLoRA["Stay with LoRA\nSmall adaptation is enough"]

    FullFT --> HigherCost["Optimizer state included\nMore memory and storage"]
    KeepLoRA --> LowerCost
    Retrieval --> Hybrid["A retrieval-augmented path\nmay fit better than training"]

    DeployChoice --> Conclusion["Look first at trainable parameters\nand deployment units, not total parameters"]
    HigherCost --> Conclusion
    Hybrid --> Conclusion

    style Ask fill:#e3f2fd,stroke:#1976d2
    style ChangeType fill:#f3e5f5,stroke:#7b1fa2
    style Tone fill:#e8f5e9,stroke:#388e3c
    style Facts fill:#fff3e0,stroke:#f57c00
    style Boundary fill:#ede7f6,stroke:#5e35b1
    style TrainAdapter fill:#e8f5e9,stroke:#2e7d32
    style FullFT fill:#ffebee,stroke:#c62828
    style Conclusion fill:#fff8e1,stroke:#f9a825
