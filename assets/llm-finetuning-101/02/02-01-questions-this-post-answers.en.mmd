flowchart LR
    Start["Questions that block dataset preparation"] --> Fields["How should instruction, input,\nand output be shaped?"]
    Start --> Loader["How do we load a tiny JSONL\nfile directly?"]
    Start --> Verify["What minimum checks must happen\nduring preprocessing?"]
    Start --> Boundary["Where should the prompt/response\nboundary live?"]

    Fields --> Contract["Define the request-response contract"]
    Loader --> Observe["Observe the real file shape\nimmediately"]
    Verify --> Checks["Check missing fields, EOS,\nlength distribution, and padding"]
    Boundary --> Masking["Set tokens before Response to -100\nso only the answer carries loss"]

    Contract --> Consistency["Achieve format consistency"]
    Observe --> Consistency
    Checks --> Consistency
    Masking --> Consistency

    Consistency --> Outcome["Carry one stable template\ninto training, evaluation, and serving"]

    style Start fill:#e3f2fd,stroke:#1976d2
    style Consistency fill:#e8f5e9,stroke:#388e3c
    style Outcome fill:#fff8e1,stroke:#f9a825
