flowchart TD
  Q["사용자 질문\n문서 집합에 관해 질의"] --> QE["질의 임베딩\n질문을 벡터로 인코딩"]
  QE --> FS["FAISS 유사도 검색\n상위 k개 청크 검색"]
  FS --> P["프롬프트 조립\n질문 + 검색 근거 + fail-closed 규칙"]
  P --> L["LLM 생성\n제공된 문서 안에서만 답변"]
  L --> A["애플리케이션 출력\n답변 또는 \"찾을 수 없음\""]

  style Q fill:#e3f2fd,stroke:#1976d2
  style QE fill:#fff3e0,stroke:#f57c00
  style FS fill:#e8f5e9,stroke:#388e3c
  style P fill:#fffde7,stroke:#f9a825
  style L fill:#f3e5f5,stroke:#7b1fa2
  style A fill:#fce4ec,stroke:#c2185b
