flowchart TD
  U["User message\nNew turn arrives"] --> A["App state\nAppend HumanMessage"]
  A --> H["Replay full history\nSystem + past turns + new turn"]
  H --> L["Stateless LLM API call\nllm.invoke(history)"]
  L --> R["Assistant reply\nReturn current answer"]
  R --> S["App state\nAppend AIMessage"]
  S --> N["Next turn\nSend the accumulated list again"]

  style U fill:#e3f2fd,stroke:#1976d2
  style A fill:#fff3e0,stroke:#f57c00
  style H fill:#fffde7,stroke:#f9a825
  style L fill:#f3e5f5,stroke:#7b1fa2
  style R fill:#e8f5e9,stroke:#388e3c
  style S fill:#fce4ec,stroke:#c2185b
  style N fill:#ede7f6,stroke:#5e35b1
