flowchart TB
    subgraph Production["Production Harness\nBind the other eight harnesses into one deployable operating stack"]
        direction TB
        Test["Test Harness\nqualify the version before rollout"]
        Obs["Observability\ntrace every run and incident"]
        Task["Task Harness\nparse user input into TaskSpec"] --> Context["Context Harness\nassemble the right context"]
        Context --> Feedback["Feedback Loop\nrun until done or escalate"]
        Feedback --> Constraint["Constraint Harness\ncheck each planned step"]
        Constraint --> Approval["Approval Gate\nask a human if the step is risky"]
        Approval --> Tools["Tool Harness\ninvoke only the exposed safe tool"]
        Test -.release gate.-> Task
        Obs -.trace coverage.-> Task
        Obs -.trace coverage.-> Tools
    end

    Tools --> Result["Response + trace + decision logs"]
    Production --> Deployable["Deployable system\nversioned stack + rollback + on-call"]
    Deployable --> Traffic["Production traffic"]

    style Production fill:#f3e5f5,stroke:#7b1fa2
    style Deployable fill:#e3f2fd,stroke:#1976d2
    style Result fill:#e8f5e9,stroke:#388e3c
    style Traffic fill:#fff8e1,stroke:#f9a825
