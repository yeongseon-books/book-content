flowchart LR
    Change["Prompt / tool / model change"] --> Criteria["Completion criteria\nrewritten as runnable checks"]
    Criteria --> Unit["Unit tests\ntool schema and validators"]
    Criteria --> Integration["Integration tests\ntask flow with tools"]
    Criteria --> Eval["Eval checks\nquality across many examples"]

    Unit --> Evidence["External evidence\npass/fail instead of 'it worked in the demo'"]
    Integration --> Evidence
    Eval --> Evidence
    Evidence --> Release["Safe to ship only when the suite passes"]

    style Change fill:#e3f2fd,stroke:#1976d2
    style Criteria fill:#f3e5f5,stroke:#7b1fa2
    style Evidence fill:#e8f5e9,stroke:#388e3c
    style Release fill:#fff8e1,stroke:#f9a825
