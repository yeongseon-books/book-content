    style Outputs fill:#fff3e0,stroke:#ef6c00
    style Criteria fill:#f3e5f5,stroke:#7b1fa2
    style Ready fill:#fff8e1,stroke:#f9a825
    style Guessing fill:#ffebee,stroke:#c62828
