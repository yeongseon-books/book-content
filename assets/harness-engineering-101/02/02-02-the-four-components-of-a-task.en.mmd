flowchart LR
    Goal["Goal\nOne sentence on what must be achieved"] --> Spec["Executable TaskSpec"]
    Inputs["Inputs\nData sources, parameters, preconditions"] --> Spec
    Outputs["Outputs\nFormat, schema, destination"] --> Spec
    Criteria["Completion criteria\nAuto-verifiable pass/fail checks"] --> Spec

    Spec --> Ready["All four present\nagent can execute without guessing"]
    Missing["Any field missing"] --> Guessing["The agent fills in blanks on its own"]

